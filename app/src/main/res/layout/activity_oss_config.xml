<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/oss_config_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/oss_config_hint"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <!-- Endpoint -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_endpoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/oss_endpoint_hint"
                android:inputType="textUri" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bucket -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_bucket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/oss_bucket_hint"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- AccessKey ID -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_access_key_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/oss_access_key_id_hint"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- AccessKey Secret -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_access_key_secret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/oss_access_key_secret_hint"
                android:inputType="textPassword" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- OSS 路径（可选） -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_oss_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/oss_path_hint"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tv_oss_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- 测试连接 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_test_oss_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_test_oss_connection"
            android:layout_marginBottom="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <!-- 上传备份 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload_oss_backup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/oss_upload"
            android:layout_marginBottom="8dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:icon="@android:drawable/ic_menu_upload" />

        <!-- 保存配置 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_oss_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_oss_config"
            android:layout_marginBottom="8dp"
            style="@style/Widget.Material3.Button" />

        <!-- 清除配置 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_oss_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clear_oss_config"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="?attr/colorError" />

    </LinearLayout>

</ScrollView>