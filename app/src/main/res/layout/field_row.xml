<?xml version="1.0" encoding="utf-8"?>
<!-- 可复用的密码详情字段行：icon + label/value 垂直布局 + 复制/切换按钮 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurfaceVariant"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 左侧字段图标 -->
        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_info"
            android:tint="?attr/colorPrimary" />

        <!-- 字段标签（小字灰色） -->
        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/field_icon"
            android:layout_toStartOf="@+id/field_action"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="标签"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <!-- 字段值（大字主色，布局锚定到label下方） -->
        <TextView
            android:id="@+id/field_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/field_label"
            android:layout_toEndOf="@id/field_icon"
            android:layout_toStartOf="@+id/field_action"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="—"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <!-- 右侧操作按钮（复制图标 / 密码可见切换） -->
        <ImageButton
            android:id="@+id/field_action"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="操作"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_content_copy"
            android:tint="?attr/colorPrimary" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
